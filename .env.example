# NeuroPit environment configuration
# Copy this file to .env and fill in real values for local development.

# ---------- Streaming ----------
KAFKA_BROKER_URL=localhost:9092
KAFKA_INTERNAL_URL=redpanda:29092

# ---------- Time series ----------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=neuropit-local-dev-token-999
INFLUXDB_ORG=neuropit
INFLUXDB_BUCKET=neuropit-telemetry

# ---------- Vector store ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ---------- IBM Granite (local Hugging Face is the default) ----------
# Default path uses the open weights from https://github.com/ibm-granite-community
# and downloads the model from Hugging Face on first run. No API key required.
GRANITE_MODEL_ID=ibm-granite/granite-3.1-8b-instruct
GRANITE_USE_LOCAL=true
GRANITE_USE_STUB=false
# Optional watsonx.ai cloud fallback. Leave empty to stay on local inference.
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ---------- Langflow ----------
LANGFLOW_API_URL=http://localhost:7860

# ---------- FastAPI gateway ----------
API_HOST=0.0.0.0
API_PORT=8000
API_JWT_SECRET=replace-with-a-long-random-string
API_JWT_ALGORITHM=HS256
API_TOKEN_EXPIRY_MINUTES=120

# ---------- Privacy / audit ----------
AUDIT_LOG_DIR=./audit_logs
BIOMETRIC_RETENTION_HOURS=24
ENCRYPTION_KEY=

# ---------- Playback ----------
DEFAULT_PLAYBACK_YEAR=2021
DEFAULT_PLAYBACK_EVENT=Abu Dhabi
DEFAULT_PLAYBACK_SESSION=R
DEFAULT_PLAYBACK_DRIVERS=VER,HAM
DEFAULT_PLAYBACK_SPEED=2.0

# ---------- Frontend ----------
NEXT_PUBLIC_NEUROPIT_WS_URL=ws://localhost:8000/ws/cognitive
NEXT_PUBLIC_NEUROPIT_API_URL=http://localhost:8000
